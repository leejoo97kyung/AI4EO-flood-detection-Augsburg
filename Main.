  {
   "cell_type": "code",
   "source": [
    "model = smp.Unet(\n",
    "    encoder_name='resnet34',\n",
    "    encoder_weights='imagenet',\n",
    "    in_channels=4,\n",
    "    classes=1,\n",
    "    activation=None\n",
    ").to(device)\n",
    "\n",
    "bce_loss  = nn.BCEWithLogitsLoss()\n",
    "dice_loss = smp.losses.DiceLoss(mode='binary')\n",
    "\n",
    "def criterion(pred, target):\n",
    "    return 0.5 * bce_loss(pred, target) + 0.5 * dice_loss(pred, target)\n",
    "\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=1e-4)\n",
    "scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\n",
    "    optimizer, patience=5, factor=0.5\n",
    ")\n",
    "\n",
    "def compute_f1_iou(pred_logits, target, threshold=0.5):\n",
    "    pred = (torch.sigmoid(pred_logits) > threshold).float()\n",
    "    tp = (pred * target).sum()\n",
    "    fp = (pred * (1 - target)).sum()\n",
    "    fn = ((1 - pred) * target).sum()\n",
    "    precision = tp / (tp + fp + 1e-6)\n",
    "    recall    = tp / (tp + fn + 1e-6)\n",
    "    f1  = 2 * precision * recall / (precision + recall + 1e-6)\n",
    "    iou = tp / (tp + fp + fn + 1e-6)\n",
    "    return f1.item(), iou.item()\n",
    "\n",
    "EPOCHS = 50\n",
    "best_f1 = 0\n",
    "history = {'train_loss': [], 'val_loss': [], 'val_f1': [], 'val_iou': []}\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    model.train()\n",
    "    train_loss = 0\n",
    "    for imgs, labels in train_loader:\n",
    "        imgs, labels = imgs.to(device), labels.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        loss = criterion(model(imgs), labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        train_loss += loss.item()\n",
    "\n",
    "    model.eval()\n",
    "    val_loss, val_f1, val_iou = 0, 0, 0\n",
    "    with torch.no_grad():\n",
    "        for imgs, labels in val_loader:\n",
    "            imgs, labels = imgs.to(device), labels.to(device)\n",
    "            pred = model(imgs)\n",
    "            val_loss += criterion(pred, labels).item()\n",
    "            f1, iou = compute_f1_iou(pred, labels)\n",
    "            val_f1 += f1\n",
    "            val_iou += iou\n",
    "\n",
    "    n = len(val_loader)\n",
    "    val_f1 /= n; val_iou /= n\n",
    "    val_loss /= n\n",
    "    train_loss /= len(train_loader)\n",
    "\n",
    "    scheduler.step(val_loss)\n",
    "    history['train_loss'].append(train_loss)\n",
    "    history['val_loss'].append(val_loss)\n",
    "    history['val_f1'].append(val_f1)\n",
    "    history['val_iou'].append(val_iou)\n",
    "\n",
    "    if val_f1 > best_f1:\n",
    "        best_f1 = val_f1\n",
    "        torch.save(model.state_dict(),\n",
    "                   '/content/drive/MyDrive/AI4EO_chips/best_unet.pth')\n",
    "        print(f'Epoch {epoch+1:02d} | Loss={train_loss:.4f} | Val F1={val_f1:.3f} | IoU={val_iou:.3f}  SAVED')\n",
    "    elif (epoch+1) % 10 == 0:\n",
    "        print(f'Epoch {epoch+1:02d} | Loss={train_loss:.4f} | Val F1={val_f1:.3f} | IoU={val_iou:.3f}')\n",
    "\n",
    "print(f'\\n Best Val F1: {best_f1:.3f}')\n"
