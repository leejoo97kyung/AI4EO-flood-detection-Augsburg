    "class TripletDataset(Dataset):\n",
    "    def __init__(self, X, y, n_triplets=1000):\n",
    "        self.X = torch.FloatTensor(X).unsqueeze(-1)\n",
    "        self.y = y\n",
    "        self.n_triplets = n_triplets\n",
    "        self.classes = np.unique(y)\n",
    "\n",
    "    def __len__(self):\n",
    "        return self.n_triplets\n",
    "\n",
    "    def __getitem__(self, _):\n",
    "        anchor_class = np.random.choice(self.classes)\n",
    "        anchor_idx = np.random.choice(np.where(self.y == anchor_class)[0])\n",
    "\n",
    "        pos_candidates = np.where(self.y == anchor_class)[0]\n",
    "        pos_candidates = pos_candidates[pos_candidates != anchor_idx]\n",
    "        if len(pos_candidates) == 0:\n",
    "            pos_idx = anchor_idx\n",
    "        else:\n",
    "            pos_idx = np.random.choice(pos_candidates)\n",
    "\n",
    "        neg_class = np.random.choice(self.classes[self.classes != anchor_class])\n",
    "        neg_idx = np.random.choice(np.where(self.y == neg_class)[0])\n",
    "\n",
    "        return (self.X[anchor_idx],\n",
    "                self.X[pos_idx],\n",
    "                self.X[neg_idx])\n",
    "\n",
    "class LSTMEncoder(nn.Module):\n",
    "    def __init__(self, input_size=1, hidden_size=64, num_layers=2, embed_dim=128):\n",
    "        super().__init__()\n",
    "        self.lstm = nn.LSTM(\n",
    "            input_size=input_size,\n",
    "            hidden_size=hidden_size,\n",
    "            num_layers=num_layers,\n",
    "            batch_first=True,\n",
    "            dropout=0.2\n",
    "        )\n",
    "        self.fc = nn.Sequential(\n",
    "            nn.Linear(hidden_size, embed_dim),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(embed_dim, embed_dim)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        out, (hn, _) = self.lstm(x)\n",
    "        embedding = self.fc(hn[-1])\n",
    "        return nn.functional.normalize(embedding, p=2, dim=1)\n",
    "\n",
    "class TripletLoss(nn.Module):\n",
    "    def __init__(self, margin=1.0):\n",
    "        super().__init__()\n",
    "        self.margin = margin\n",
    "\n",
    "    def forward(self, anchor, positive, negative):\n",
    "        dist_pos = (anchor - positive).pow(2).sum(1)\n",
    "        dist_neg = (anchor - negative).pow(2).sum(1)\n",
    "        loss = torch.clamp(dist_pos - dist_neg + self.margin, min=0)\n",
    "        return loss.mean()\n",
    "\n",
    "triplet_ds = TripletDataset(X_norm, y, n_triplets=2000)\n",
    "triplet_loader = DataLoader(triplet_ds, batch_size=32, shuffle=True)\n",
    "\n",
    "encoder = LSTMEncoder(input_size=1, hidden_size=64,\n",
    "                      num_layers=2, embed_dim=128).to(device)\n",
    "criterion_triplet = TripletLoss(margin=1.0)\n",
    "optimizer_enc = torch.optim.Adam(encoder.parameters(), lr=1e-3)\n",
    "\n",
    "print(f'Model parameters: {sum(p.numel() for p in encoder.parameters()):,}')\n",
    "print('Triplet dataset ready.')\n"
