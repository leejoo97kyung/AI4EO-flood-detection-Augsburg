    "        img, label = load_chip_pair(i)\n",
    "        all_imgs.append(img)\n",
    "        all_labels.append(label)\n",
    "        print(f'chip_{i:02d}: img={img.shape}, label flood%={label.mean()*100:.1f}%')\n",
    "    except Exception as e:\n",
    "        print(f'chip_{i:02d}: SKIP ({e})')\n",
    "\n",
    "print(f'\\nTotal {len(all_imgs)} chips loaded')\n"
