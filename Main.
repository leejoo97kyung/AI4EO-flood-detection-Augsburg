   "source": [
    "import numpy as np\n",
    "\n",
    "all_imgs_clean = []\n",
    "all_labels_clean = []\n",
    "\n",
    "for i, (img, label) in enumerate(zip(all_imgs, all_labels)):\n",
    "    if np.isnan(img).any():\n",
    "        nan_ratio = np.isnan(img).mean()\n",
    "        if nan_ratio > 0.01:\n",
    "            print(f'chip_{i:02d}:  Excluded (NaN {nan_ratio*100:.1f}%)')\n",
    "            continue\n",
    "        else:\n",
    "            img = np.nan_to_num(img, nan=0.0)\n",
    "            print(f'chip_{i:02d}: ️ NaN replaced with 0')\n",
    "    else:\n",
    "        print(f'chip_{i:02d}:  OK')\n",
    "\n",
    "    all_imgs_clean.append(img)\n",
    "    all_labels_clean.append(label)\n",
    "\n",
    "print(f'\\nFinal chip count: {len(all_imgs_clean)}')\n",
    "\n",
    "SAR_MIN, SAR_MAX = -30.0, 5.0\n",
    "all_imgs_norm = [(img - SAR_MIN) / (SAR_MAX - SAR_MIN) for img in all_imgs_clean]\n",
    "all_labels_clean_final = all_labels_clean\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "indices = list(range(len(all_imgs_norm)))\n",
    "train_idx, temp_idx = train_test_split(indices, test_size=6, random_state=42)\n",
    "val_idx, test_idx   = train_test_split(temp_idx, test_size=3, random_state=42)\n",
    "print(f'Train: {len(train_idx)}, Val: {len(val_idx)}, Test: {len(test_idx)}')\n",
    "\n",
    "train_ds = FloodDataset([all_imgs_norm[i] for i in train_idx],\n",
    "                        [all_labels_clean_final[i] for i in train_idx], train_transform)\n",
    "val_ds   = FloodDataset([all_imgs_norm[i] for i in val_idx],\n",
    "                        [all_labels_clean_final[i] for i in val_idx], val_transform)\n",
    "test_ds  = FloodDataset([all_imgs_norm[i] for i in test_idx],\n",
    "                        [all_labels_clean_final[i] for i in test_idx], val_transform)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=4, shuffle=True)\n",
    "val_loader   = DataLoader(val_ds,   batch_size=4, shuffle=False)\n",
    "test_loader  = DataLoader(test_ds,  batch_size=4, shuffle=False)\n"
   ],
