    "\n",
    "    with rasterio.open(CHIP_DIR / f'chip_label_{idx_str}.tif') as src:\n",
    "        label = src.read(1).astype(np.float32)\n",
    "\n",
    "    return img, label\n",
    "\n",
    "all_imgs, all_labels = [], []\n",
    "\n",
    "for i in range(21):\n",
